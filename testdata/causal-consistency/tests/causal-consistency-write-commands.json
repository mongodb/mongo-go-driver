        "id": "database0",
        "client": "client0",
        "databaseName": "causal-consistency-tests"
      }
    },
    {
      "collection": {
        "id": "collection0",
        "database": "database0",
        "collectionName": "test"
      }
    },
    {
      "session": {
        "id": "session0",
        "client": "client0",
        "sessionOptions": {
          "causalConsistency": true
        }
      }
    }
